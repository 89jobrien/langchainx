# langchainx — environment variables example
# Copy to .env and fill in values, or use op run / dotenvx to inject secrets.

# ── LLM backends ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_API_BASE=                        # optional — override for OpenAI-compatible APIs
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
MISTRAL_API_KEY=
OLLAMA_HOST=http://localhost:11434      # default Ollama base URL

# ── Embeddings ────────────────────────────────────────────────────────────────
# Most embedding backends reuse the LLM keys above.
# FastEmbed is local — no key needed.

# ── Vector stores ─────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql://localhost:5432/langchainx
SURREALDB_URL=ws://localhost:8000
SURREALDB_NS=langchainx
SURREALDB_DB=langchainx
SURREALDB_USER=
SURREALDB_PASS=
QDRANT_URL=http://localhost:6334
QDRANT_API_KEY=                         # optional — leave blank for local
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USER=
OPENSEARCH_PASS=
SQLITE_PATH=./langchainx.db

# ── Tools ─────────────────────────────────────────────────────────────────────
SERPAPI_API_KEY=
WOLFRAM_APP_ID=

# ── Issue tracking ────────────────────────────────────────────────────────────
LANGCHAINX_GH_REPO=89jobrien/langchainx
LANGCHAINX_LINEAR_TEAM=Jobrien
LANGCHAINX_LINEAR_QUERY=langchainx

# ── Dev / test ────────────────────────────────────────────────────────────────
RUST_LOG=langchainx=debug
