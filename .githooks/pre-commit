#!/usr/bin/env bash
# .githooks/pre-commit — gitflow branch enforcement
#
# Rules:
#   - Direct commits to main are blocked (releases land via release-finish workflow)
#   - Commits to develop are warned against (use feature/* branches instead)
#   - Branch names must follow gitflow conventions
#   - chore(version): bump commits (from the bot) are always allowed through

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")

# ── Always allow bot version-bump commits ────────────────────────────────────
# Read the commit message from MERGE_MSG or the prepared message file if present.
# During pre-commit the message isn't finalised yet, so we check the index instead:
# if the only staged file is Cargo.toml and the message starts with chore(version),
# let it through. We detect this via the GIT_EDITOR env or by checking COMMIT_EDITMSG.
if [ -f "$(git rev-parse --git-dir)/COMMIT_EDITMSG" ]; then
    MSG=$(cat "$(git rev-parse --git-dir)/COMMIT_EDITMSG" 2>/dev/null || echo "")
    if echo "$MSG" | grep -qE '^chore\(version\): bump'; then
        exit 0
    fi
fi

# ── Block direct commits to main ─────────────────────────────────────────────
if [ "$BRANCH" = "main" ]; then
    echo -e "${RED}✗ BLOCKED: Direct commits to 'main' are not allowed.${NC}"
    echo -e "${CYAN}  Gitflow: main receives merges only from release/* and hotfix/* branches.${NC}"
    echo -e "${CYAN}  To fix a bug: git checkout -b hotfix/<name> main${NC}"
    echo -e "${CYAN}  To release:   dispatch the release-cut workflow on GitHub.${NC}"
    exit 1
fi

# ── Warn on direct commits to develop ────────────────────────────────────────
if [ "$BRANCH" = "develop" ]; then
    echo -e "${YELLOW}⚠ WARNING: Committing directly to 'develop'.${NC}"
    echo -e "${YELLOW}  Gitflow: develop should receive merges from feature/* branches.${NC}"
    echo -e "${YELLOW}  Consider: git checkout -b feature/<name> develop${NC}"
    echo -e "${YELLOW}  Proceeding in 3s — Ctrl-C to cancel...${NC}"
    sleep 3
fi

# ── Enforce branch naming convention ─────────────────────────────────────────
VALID_PATTERN='^(main|develop|feature/.+|release/[0-9]+\.[0-9]+\.[0-9]+|hotfix/.+)$'
if ! echo "$BRANCH" | grep -qE "$VALID_PATTERN"; then
    echo -e "${RED}✗ BLOCKED: Branch name '${BRANCH}' does not follow gitflow conventions.${NC}"
    echo -e "${CYAN}  Allowed patterns:${NC}"
    echo -e "${CYAN}    feature/<name>        — new features${NC}"
    echo -e "${CYAN}    release/<M.m.p>       — release preparation${NC}"
    echo -e "${CYAN}    hotfix/<name>         — urgent fixes from main${NC}"
    echo -e "${CYAN}    develop               — integration branch${NC}"
    echo -e "${CYAN}    main                  — release branch (no direct commits)${NC}"
    exit 1
fi

# ── Warn if committing to a release branch without a version change ───────────
if echo "$BRANCH" | grep -qE '^release/'; then
    RELEASE_VER=$(echo "$BRANCH" | sed 's|release/||')
    CARGO_VER=$(grep -m1 '^version = ' Cargo.toml 2>/dev/null | sed 's/version = "\(.*\)"/\1/' || echo "")
    if [ -n "$CARGO_VER" ] && [ "$CARGO_VER" != "$RELEASE_VER" ]; then
        echo -e "${YELLOW}⚠ WARNING: Cargo.toml version (${CARGO_VER}) does not match release branch (${RELEASE_VER}).${NC}"
        echo -e "${YELLOW}  The release-cut workflow should have set this. Proceeding anyway.${NC}"
    fi
fi

exit 0
